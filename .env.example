# Example environment configuration
# Copy this to .env and customize as needed

# Server Settings
HOST=0.0.0.0
PORT=8000

# Audio Settings (must match ESPHome configuration)
SAMPLE_RATE=48000  # 48kHz to match example-config.yaml
SAMPLE_WIDTH=4     # 4 bytes (32-bit) to match example-config.yaml
CHANNELS=1

# Buffer Settings
BUFFER_DURATION_SECONDS=60.0
PRE_WAKE_DURATION_SECONDS=2.0
POST_WAKE_DURATION_SECONDS=3.0

# Storage Settings
OUTPUT_DIR=/app/audio_clips

# MQTT Settings
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=wakeword/debug
MQTT_CLIENT_ID=wakeword-ingest-service
# Base topics for multi-assistant support (wildcard + will be automatically added)
# Devices should publish to: satellite1/audio_debug/pcm/{assistant_id}
MQTT_AUDIO_TOPIC=satellite1/audio_debug/pcm  # Base topic for audio data
MQTT_EVENT_TOPIC=satellite1/audio_debug/meta  # Base topic for wake word events
MQTT_AUDIO_INFO_TOPIC=satellite1/audio_debug/meta  # Base topic for wake word events

# Home Assistant Discovery
HASS_DISCOVERY_PREFIX=homeassistant
